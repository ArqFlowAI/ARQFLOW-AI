# App
# Produção (Vercel): https://arqflow-ai.vercel.app
# Local development URL:
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=ARQFLOW AI

# Supabase Auth (obrigatório)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Redirect URLs no Supabase: /api/auth/callback e /recuperar-senha/atualizar
# Ver supabase/AUTH_SETUP.md
# Prisma: gere com npm run env:setup (SUPABASE_DB_PASSWORD=...)
# DATABASE_URL = Transaction pooler :6543 | DIRECT_URL = Session pooler :5432
DATABASE_URL=postgresql://postgres.your-project:password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.your-project:password@aws-0-region.pooler.supabase.com:5432/postgres

# OpenAI
OPENAI_API_KEY=sk-your-openai-key
OPENAI_CONCEPT_MODEL=gpt-4o

# Image AI (Replicate or Fal)
REPLICATE_API_TOKEN=r8_your-replicate-token
REPLICATE_FLUX_MODEL=black-forest-labs/flux-schnell
FAL_KEY=your-fal-key
IMAGE_PROVIDER=replicate

# Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-secret
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key
STRIPE_PRICE_BASIC=price_basic_id
STRIPE_PRICE_PRO=price_pro_id
STRIPE_PRICE_PREMIUM=price_premium_id

# Kiwify
KIWIFY_WEBHOOK_SECRET=your-kiwify-webhook-secret

# Resend
RESEND_API_KEY=re_your-resend-key
RESEND_FROM_EMAIL=ARQFLOW AI <onboarding@arqflow.ai>

# n8n
N8N_WEBHOOK_URL=https://your-n8n.app/webhook
N8N_API_KEY=your-n8n-api-key

# WhatsApp (Z-API / Twilio)
ZAPI_INSTANCE_ID=your-zapi-instance
ZAPI_TOKEN=your-zapi-token
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Security
CRON_SECRET=your-cron-secret

# --- Produção (Vercel) ---
# 1. Copie todas as variáveis acima para Vercel → Settings → Environment Variables
# 2. DATABASE_URL (porta 6543 + pgbouncer) e DIRECT_URL (porta 5432) do Supabase Pooler
# 3. NEXT_PUBLIC_APP_URL = URL final do deploy (ex: https://arqflow.vercel.app)
# 4. Supabase Auth: Site URL + Redirect URLs com o domínio de produção
# 5. Webhooks: /api/webhooks/stripe, /api/webhooks/kiwify
# 6. Guia completo: DEPLOY.md
